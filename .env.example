# VoxGate configuration. Copy to `.env` and fill in.
# For multiple instances side by side, see docs/setup.md ("Multi-instance").

# ─── Required: auth ────────────────────────────────────────────────────
# OAuth 2.0 Web Client ID from Google Cloud Console
# (https://console.cloud.google.com/apis/credentials). Add every public
# VoxGate URL as an "Authorized JavaScript origin" on that client.
GOOGLE_CLIENT_ID=

# Comma-separated list of permitted Google e-mail addresses. Optional
# `:provider` suffix per entry binds the e-mail to one identity provider
# (e.g. "alice@example.com:google"). Without a suffix, every configured
# provider is acceptable.
ALLOWED_EMAILS=

# Server-side key used to sign session cookies. Generate with:
#   SESSION_SECRET=$(openssl rand -hex 32)
# If empty, a fresh secret is generated per container start (every
# restart logs all users out — fine for dev, bad for production).
SESSION_SECRET=

# Lifetime of a login session. Default 7 days.
# SESSION_COOKIE_TTL_SECONDS=604800

# Set to 1 in production (HTTPS). Required so browsers keep the session
# cookie. Use 0 only for local http://localhost development.
COOKIE_SECURE=0

# Login attempts per IP per minute (per provider).
# AUTH_LOGIN_RATE_LIMIT_PER_MINUTE=10

# ─── Required: backend ────────────────────────────────────────────────
# Configure at least ONE backend:

# (a) Direct Anthropic API — easiest, no extra service needed.
ANTHROPIC_API_KEY=
SYSTEM_PROMPT=You are a helpful assistant. Answer concisely.

# (b) Forward to a custom HTTP backend (e.g. Claude Code on your Mac).
# TARGET_URL=http://host.docker.internal:9000/prompt
# TARGET_TOKEN=

# Origin allowed to call the API from a browser (the PWA). Leave empty
# to block cross-origin requests entirely.
ALLOWED_ORIGIN=

# ─── Branding ──────────────────────────────────────────────────────────
INSTANCE_NAME=VoxGate
INSTANCE_COLOR=#c8ff00
# Default language tag (BCP-47). Affects which TTS voice the device
# tries to use first.
SPEECH_LANG=de-CH
# Languages selectable in the UI. Comma-separated BCP-47 tags. Defaults
# to a five-language European set (de-CH,fr-CH,it-CH,en-US,es-ES).
# See docs/setup.md for what the API actually recognizes.
# SPEECH_LANGS=de-CH,fr-CH,it-CH,en-US,es-ES

# ─── Tuning (optional) ─────────────────────────────────────────────────
# RATE_LIMIT_PER_MINUTE=30
# SESSION_TTL_SECONDS=1800
# MAX_SESSIONS=1000
# MAX_PROMPT_LENGTH=4000
# REQUEST_TIMEOUT=120
# CLAUDE_MODEL=claude-sonnet-4-5

# Set to 1 only when running behind a trusted reverse proxy (Caddy/Nginx)
# that reliably sets X-Forwarded-For. Otherwise rate limiting can be
# bypassed by spoofed headers.
TRUST_PROXY_HEADERS=0

# ─── Future identity providers (placeholders, not implemented yet) ─────
# Once a generic OIDC verifier ships, additional providers slot in here:
# MICROSOFT_TENANT_ID=
# MICROSOFT_CLIENT_ID=
