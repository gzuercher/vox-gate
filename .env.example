# VoiceClaude environment variables

# --- Instance identity (shown in UI) ---
INSTANCE_NAME=Claude
INSTANCE_COLOR=#c8ff00
SPEECH_LANG=de-CH

# --- Forwarding target ---
# The backend URL this instance sends voice text to
TARGET_URL=http://localhost:9000/prompt
# Optional: Bearer token for authenticating with the target
TARGET_TOKEN=

# --- Gateway security ---
# Bearer token for the /prompt endpoint (required for production)
API_TOKEN=
# Allowed CORS origin (e.g. https://voice.example.com)
ALLOWED_ORIGIN=

# --- Limits ---
MAX_PROMPT_LENGTH=4000
REQUEST_TIMEOUT=120

# --- Direct Claude backend (/claude endpoint) ---
ANTHROPIC_API_KEY=
SYSTEM_PROMPT=

# --- Docker Compose tokens (one per instance) ---
API_TOKEN_CLAUDE=
API_TOKEN_DOKBOT=
