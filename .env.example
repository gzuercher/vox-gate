# Raptus Projekt Umgebungsvariablen
# Kopiere diese Datei zu .env.local und fülle die Werte aus

# GitHub (für MCP-Server)
GITHUB_TOKEN=                 # Personal Access Token (repo, read:org)

# Datenbank (Next.js Projekte)
DATABASE_URL=                 # PostgreSQL Connection String

# Authentifizierung (Next.js)
NEXTAUTH_SECRET=              # Zufälliger String: openssl rand -base64 32
NEXTAUTH_URL=                 # Basis-URL (z.B. https://app.kunde.ch)

# Optionale MCP-Server (bei Bedarf aktivieren)
# FIGMA_TOKEN=               # Figma Personal Access Token
# WEBFLOW_TOKEN=             # Webflow API Token
# SLACK_BOT_TOKEN=           # Slack Bot Token
