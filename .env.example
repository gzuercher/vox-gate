# VoxGate configuration. Copy to `.env` and fill in.
# For multiple instances side by side, see SETUP.md ("Multi-instance").

# ─── Required ──────────────────────────────────────────────────────────
# Bearer token clients must send. Leave empty to auto-generate one per
# run (printed to logs). For production set a stable value:
#   API_TOKEN=$(openssl rand -hex 32)
API_TOKEN=

# Configure at least ONE backend:

# (a) Direct Anthropic API — easiest, no extra service needed.
ANTHROPIC_API_KEY=
SYSTEM_PROMPT=You are a helpful assistant. Answer concisely.

# (b) Forward to a custom HTTP backend (e.g. Claude Code on your Mac).
# TARGET_URL=http://host.docker.internal:9000/prompt
# TARGET_TOKEN=

# Origin allowed to call the API from a browser (the PWA). Leave empty
# to block cross-origin requests entirely.
ALLOWED_ORIGIN=

# ─── Branding ──────────────────────────────────────────────────────────
INSTANCE_NAME=VoxGate
INSTANCE_COLOR=#c8ff00
SPEECH_LANG=de-CH

# ─── Tuning (optional) ─────────────────────────────────────────────────
# RATE_LIMIT_PER_MINUTE=30
# SESSION_TTL_SECONDS=1800
# MAX_SESSIONS=1000
# MAX_PROMPT_LENGTH=4000
# REQUEST_TIMEOUT=120
# CLAUDE_MODEL=claude-sonnet-4-5

# Set to 1 only when running behind a trusted reverse proxy (Caddy/Nginx)
# that reliably sets X-Forwarded-For. Otherwise rate limiting can be
# bypassed by spoofed headers.
TRUST_PROXY_HEADERS=0
