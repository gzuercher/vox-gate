# ─── Caddy bundle ──────────────────────────────────────────────────────
# Public hostname pointing at this server (DNS A/AAAA already set).
VOXGATE_DOMAIN=voxgate.example.com
# Address Let's Encrypt sends expiry notices to.
ACME_EMAIL=you@example.com

# ─── VoxGate auth (required) ──────────────────────────────────────────
# OAuth 2.0 Web Client ID from Google Cloud Console. Add VOXGATE_DOMAIN
# (https://${VOXGATE_DOMAIN}) as an Authorized JavaScript origin.
GOOGLE_CLIENT_ID=

# Comma-separated list of permitted Google e-mail addresses. Optional
# `:provider` suffix per entry (e.g. "alice@example.com:google").
ALLOWED_EMAILS=

# Sign session cookies. Generate with: openssl rand -hex 32
SESSION_SECRET=

# Caddy terminates TLS — keep COOKIE_SECURE=1 so the session cookie is
# only sent over HTTPS.
COOKIE_SECURE=1

# ─── Backend (pick one or both) ───────────────────────────────────────
ANTHROPIC_API_KEY=
SYSTEM_PROMPT=You are a helpful assistant. Answer concisely.
# TARGET_URL=http://host.docker.internal:9000/prompt
# TARGET_TOKEN=

# Browser origin allowed to call the API (must match VOXGATE_DOMAIN).
ALLOWED_ORIGIN=https://voxgate.example.com

# ─── Branding ──────────────────────────────────────────────────────────
INSTANCE_NAME=VoxGate
INSTANCE_COLOR=#c8ff00
SPEECH_LANG=de-CH

# ─── Tuning (optional) ─────────────────────────────────────────────────
# RATE_LIMIT_PER_MINUTE=30
# AUTH_LOGIN_RATE_LIMIT_PER_MINUTE=10
# SESSION_TTL_SECONDS=1800
# SESSION_COOKIE_TTL_SECONDS=604800
# MAX_SESSIONS=1000
